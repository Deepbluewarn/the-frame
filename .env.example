# === 로컬 개발용 (npm run dev) ===
# 인프라는 docker-compose.dev.yml (mongo+minio만) 로 띄운다.

# 관리자 Basic Auth (원하는 값으로)
ADMIN_USER=admin
ADMIN_PASS=admin

# SEO base URL
SITE_URL=http://localhost:3031

# MongoDB (dev compose가 로컬 27017에 노출)
MONGODB_URI=mongodb://localhost:27017/the-frame

# MinIO (dev compose가 로컬 9000에 노출)
# 콘솔 http://localhost:9001, root minioadmin/minioadmin
# → 콘솔에서 버킷 생성 후 access key 발급받아 아래 채운다
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=the-frame
