# === 프로덕션 (docker compose --env-file .env.prod) ===

# 관리자 Basic Auth (강한 값으로)
ADMIN_USER=
ADMIN_PASS=

# 공개 도메인 (SEO/sitemap용)
SITE_URL=https://photos.example.com

# Mongo는 compose 안에서 자동 (mongo:27017), 값은 컴포즈가 주입
# MONGODB_URI 는 override 하지 말 것

# MinIO 공개 URL (Caddy 프록시 통과 URL, 브라우저·서버 공통)
S3_ENDPOINT=https://s3.example.com
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=the-frame

# MinIO 컨테이너 root (콘솔 로그인)
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# Umami analytics
UMAMI_DB_PASSWORD=change-me
UMAMI_APP_SECRET=change-me-too

# Umami tracking (대시보드에서 웹사이트 등록 후 발급되는 값)
NEXT_PUBLIC_UMAMI_URL=https://analytics.example.com
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
